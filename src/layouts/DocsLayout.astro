---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Design System',
  description = 'Documentación interna del sistema de diseño',
} = Astro.props as Props;
---

<html lang="es-MX">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />

    <title>{title}</title>

    <meta
      name="description"
      content={description}
    />
  </head>

  <body>
    <div class="docs-shell">
      <slot />
    </div>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(body) {
    margin: 0;
    min-height: 100vh;

    font-family:
      Inter,
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;

    background:
      radial-gradient(
        circle at top left,
        rgba(99, 102, 241, 0.1),
        transparent 20%
      ),
      linear-gradient(
        180deg,
        #f8fafc 0%,
        #eef2ff 100%
      );

    color: #111827;
  }

  .docs-shell {
    min-height: 100vh;
  }
</style>
